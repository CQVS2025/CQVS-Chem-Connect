# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_BASE_URL=https://api.mailgun.net/v3/your-mailgun-domain
# App
NEXT_PUBLIC_APP_URL=http://localhost:3000


# GoHighLevel — Marketing Module
GHL_LOCATION_ID=FQ5OnSrbC8BdZbTnWvp8
GHL_PRIVATE_INTEGRATION_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Shared secret used to verify GHL webhooks (HMAC-SHA256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GHL_WEBHOOK_SECRET=

# --- GHL Marketplace App (for LCEmailStats — accurate per-message attribution) ---
# Obtained from https://marketplace.gohighlevel.com/ → My Apps → Manage → Secrets.
GHL_MARKETPLACE_CLIENT_ID=
GHL_MARKETPLACE_CLIENT_SECRET=
# Ed25519 public key GHL uses to sign LCEmailStats webhook bodies.
# Fixed value published by GHL in their Webhook Integration Guide.
GHL_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MCowBQYDK2VwAyEAi2HR1srL4o18O8BRa7gVJY7G7bupbN3H9AwJrHCDiOg=
-----END PUBLIC KEY-----"

# Cron secret for the scheduled-campaign worker. GitHub Actions sends this
# in the `x-cron-secret` header when calling /api/marketing/campaigns/run-scheduled.
MARKETING_CRON_SECRET=

# --- SEO ---
# Public site URL — used for canonical URLs, JSON-LD, OG tags, sitemap, robots.
NEXT_PUBLIC_SITE_URL=https://www.cqvs-chemconnect.com.au

# Search-console verification tokens. Get these from:
#   Google Search Console: https://search.google.com/search-console
#     Add property → choose "URL prefix" → pick "HTML tag" verification
#     → copy the value of the `content="..."` attribute below
#   Bing Webmaster Tools: https://www.bing.com/webmasters
#     Add site → "Add a meta tag" → copy the `content="..."` value
#   Yandex (optional, only if you want Russian-language coverage):
#     https://webmaster.yandex.com → Add site → Meta tag method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# Customer reviews — toggle the on-page Reviews / AggregateRating display.
# Default is OFF. Only set to "true" once real reviews are being collected
# and the dataset reflects authentic buyer feedback. Leaving sample/seed
# reviews visible in production violates Google's review policy and can
# trigger a manual action — and is a misleading-conduct risk under the
# Australian Consumer Law.
NEXT_PUBLIC_REVIEWS_VISIBLE=false

# Microsoft Clarity — free behavioural analytics (heatmaps, session
# recordings, insights). Get the project ID from:
#   https://clarity.microsoft.com → your project → Settings → Overview
# Leaving this empty disables Clarity entirely (no script loaded — useful
# for local dev / staging so test sessions don't pollute production data).
NEXT_PUBLIC_CLARITY_PROJECT_ID=
